{
  "_meta": {
    "version": "1.0",
    "description": "图片提取预设配置库",
    "last_updated": "2024-01-20"
  },
  
  "chatgpt.com": {
    "name": "ChatGPT",
    "description": "OpenAI ChatGPT 官方站点",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": ".agent-turn .markdown",
      "debounce_seconds": 2.0,
      "wait_for_load": true,
      "load_timeout_seconds": 5.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "ChatGPT 的图片通常在 markdown 容器内，使用标准 img 标签"
  },
  
  "gemini.google.com": {
    "name": "Google Gemini",
    "description": "Google Gemini AI",
    "image_extraction": {
      "enabled": true,
      "modalities": {
        "image": true,
        "audio": true,
        "video": true
      },
      "selector": "img",
      "audio_selector": "generated-music audio, generated-music source, audio, audio source",
      "video_selector": "generated-music video, video-player video, response-element video, video",
      "container_selector": "response-element, single-image.generated-image, .generated-image, generated-music, .attachment-container, .markdown-main-panel",
      "debounce_seconds": 2.5,
      "wait_for_load": true,
      "load_timeout_seconds": 6.0,
      "download_blobs": true,
      "max_size_mb": 100,
      "mode": "all"
    },
    "notes": "Gemini 可能使用懒加载，建议稍长的 debounce 时间"
  },
  
  "aistudio.google.com": {
    "name": "Google AI Studio",
    "description": "Google AI Studio (Gemini API)",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": ".chat-turn-container.model ms-cmark-node",
      "debounce_seconds": 2.0,
      "wait_for_load": true,
      "load_timeout_seconds": 5.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "AI Studio 使用自定义 Web Components"
  },
  
  "chat.deepseek.com": {
    "name": "DeepSeek",
    "description": "DeepSeek AI 对话",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": "div.ds-markdown",
      "debounce_seconds": 2.0,
      "wait_for_load": true,
      "load_timeout_seconds": 5.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "DeepSeek 使用 ds-markdown 容器"
  },
  
  "www.doubao.com": {
    "name": "豆包",
    "description": "字节跳动豆包 AI",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": null,
      "debounce_seconds": 2.0,
      "wait_for_load": true,
      "load_timeout_seconds": 10.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "豆包使用 data-testid 属性定位"
  },
  
  "grok.com": {
    "name": "Grok",
    "description": "xAI Grok",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": ".response-content-markdown",
      "debounce_seconds": 2.0,
      "wait_for_load": true,
      "load_timeout_seconds": 5.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "Grok 的响应容器使用 response-content-markdown"
  },
  
  "lmarena.ai": {
    "name": "LMArena",
    "description": "Language Model Arena",
    "image_extraction": {
      "enabled": true,
      "selector": "img",
      "container_selector": ".no-scrollbar",
      "debounce_seconds": 2.5,
      "wait_for_load": true,
      "load_timeout_seconds": 6.0,
      "download_blobs": true,
      "max_size_mb": 10,
      "mode": "all"
    },
    "notes": "LMArena 可能有多个模型同时输出，使用 prose 容器"
  }
}
