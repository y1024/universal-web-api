# ======================================
# Universal Web-to-API 配置文件
# ======================================

# ========== 版本信息 ==========
# 当前版本（自动更新时会修改）
CURRENT_VERSION=1.01

# ========== 自动更新配置 ==========
# 是否启用自动更新（true/false）
AUTO_UPDATE_ENABLED=true

# GitHub 仓库地址（用于检查更新）
GITHUB_REPO=lumingya/universal-web-api

# 更新时保留的文件/目录（逗号分隔）
UPDATE_PRESERVE=chrome_profile,venv,.env.local,logs

# ========== 服务配置 ==========
# 监听地址（0.0.0.0 允许外部访问，127.0.0.1 仅本地）
APP_HOST=127.0.0.1

# 监听端口
APP_PORT=8199

# ======================================
# Universal Web-to-API 配置文件
# ======================================

# ========== 版本信息 ==========
# 当前版本（自动更新时会修改）
CURRENT_VERSION=1.01

# ========== 自动更新配置 ==========
# 是否启用自动更新（true/false）
AUTO_UPDATE_ENABLED=true

# GitHub 仓库地址（用于检查更新）
GITHUB_REPO=lumingya/universal-web-api

# 更新时保留的文件/目录（逗号分隔）
UPDATE_PRESERVE=chrome_profile,venv,.env.local,logs

# ========== 服务配置 ==========
# 监听地址（0.0.0.0 允许外部访问，127.0.0.1 仅本地）
APP_HOST=127.0.0.1

# 监听端口
APP_PORT=8199

# 调试模式（true 开启 API 文档和详细错误）
APP_DEBUG=true

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=DEBUG
# ========== 认证配置 ==========
# 是否启用 API 认证
AUTH_ENABLED=your-secret-here

# Bearer Token（AUTH_ENABLED=true 时必须设置）
AUTH_TOKEN=

# ========== CORS 配置 ==========
# 是否启用 CORS
CORS_ENABLED=true

# 允许的跨域源
CORS_ORIGINS=*

# ========== 浏览器配置 ==========
# Chrome 远程调试端口
BROWSER_PORT=9222

# ========== Dashboard 配置 ==========
DASHBOARD_ENABLED=true
DASHBOARD_FILE=static/index.html

# ========== AI 分析配置 ==========
HELPER_API_KEY=your-api-key-here
HELPER_BASE_URL=http://127.0.0.1:8199/url/gemini.com/v1
# API 提供商类型（auto=自动检测, openai=OpenAI兼容, gemini=Gemini官方, claude=Claude官方）
HELPER_API_PROVIDER=auto
HELPER_MODEL=gemini-3.0-pro
MAX_HTML_CHARS=120000
CANVAS_IMAGE_MAX_SIZE=1024

# ========== 配置文件 ==========
SITES_CONFIG_FILE=config/sites.json

# 自定义浏览器路径（可选，留空则自动检测 Chrome/Edge/Brave 等）
# BROWSER_PATH=
# 浏览器配置目录（留空则使用项目内 chrome_profile）
# BROWSER_PROFILE_DIR=
# Chrome 配置名称（常见值：Default、Profile 1）
# BROWSER_PROFILE_NAME=
# 解析路径
PUBLIC_BASE_URL=http://127.0.0.1:8199
# ===== 代理配置 =====
# 是否启用代理 (true/false)
PROXY_ENABLED=false
# 代理地址 (支持 socks5:// 或 http://)
# 示例: socks5://127.0.0.1:1080 或 http://127.0.0.1:7890
PROXY_ADDRESS=socks5://127.0.0.1:1080
# 不走代理的地址 (逗号分隔)
PROXY_BYPASS=localhost,127.0.0.1

TOOL_CALLING_RETRY_STRATEGY=focused_repair
TOOL_CALLING_INTERNAL_RETRY_MAX=2
TOOL_CALLING_MAX_TOOL_RESULT_CHARS=300000

PROFILE_CLEAN_ENABLED=true

TOOL_CALLING_ALLOW_MEDIA_POSTPROCESS=false
TOOL_CALLING_SANITIZE_ASSISTANT_CONTENT=true

PYTHON_INSTALL_VERSION=3.13.6
TOOL_CALLING_PROMPT_PADDING_OBFUSCATE=false
TOOL_CALLING_PROMPT_PADDING_ENABLED=true

# ========== Ngrok 内网穿透配置 ==========
# Cpolar 官方 ZIP 的 SHA-256；未配置时不会自动下载并执行 Cpolar
CPOLAR_SHA256=

# 您的 Ngrok Authtoken (从 https://dashboard.ngrok.com/get-started/your-authtoken 获取)
NGROK_AUTHTOKEN=

# 您的 Ngrok 静态域名 (例如: xxx-yyy-zzz.ngrok-free.app)
NGROK_STATIC_DOMAIN=vertical-smolder-purely.ngrok-free.dev

# 内网穿透安全访问设置 - Basic Auth 账号（留空则不启用密码保护）
NGROK_AUTH_USER=your-secret-here

# 内网穿透安全访问设置 - Basic Auth 密码（建议设置一个强密码，留空则不启用密码保护）
NGROK_AUTH_PASSWORD=your-secret-here

DASHBOARD_AUTH_ENABLED=your-secret-here
DASHBOARD_AUTH_TOKEN=

# 允许执行非沙箱 Python 命令（以支持平滑鼠标轨迹和物理点击）
CMD_ALLOW_UNSAFE_PYTHON_COMMANDS=true

